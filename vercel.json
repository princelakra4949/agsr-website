{
  "version": 2,
  "functions": {
    "api/payload.js": {
      "maxDuration": 30,
      "includeFiles": "src/**,payload.config.js"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/payload" },
    { "source": "/admin/:path*", "destination": "/api/payload" },
    { "source": "/admin", "destination": "/api/payload" },
    { "source": "/media/:path*", "destination": "/api/payload" }
  ]
}
